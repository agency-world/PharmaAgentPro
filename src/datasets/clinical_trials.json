  {
    "trial_id": "PCT-2024-0147",
    "title": "A Randomized, Double-Blind, Placebo-Controlled Phase II Study of Nexavirin in Adults with Moderate COVID-19",
    "compound_id": "PHA-001",
    "compound_name": "Nexavirin",
    "phase": "Phase II",
    "status": "Enrolling",
    "design": "Randomized, double-blind, placebo-controlled, parallel-group",
    "primary_endpoint": "Time to sustained clinical recovery by Day 28",
    "secondary_endpoints": [
      "Viral load reduction at Day 5",
      "Rate of hospitalization by Day 14",
      "Change in inflammatory biomarkers (CRP, IL-6)",
      "Safety and tolerability assessment"
    ],
    "population": {
      "target_enrollment": 420,
      "current_enrollment": 287,
      "age_range": "18-75",
      "inclusion_criteria": [
        "Confirmed SARS-CoV-2 infection by RT-PCR",
        "Symptom onset within 5 days",
        "SpO2 >= 93% on room air",
        "At least one risk factor for severe disease"
      ],
      "exclusion_criteria": [
        "Requiring supplemental oxygen at screening",
        "eGFR < 30 mL/min",
        "Severe hepatic impairment (Child-Pugh C)",
        "Concurrent use of strong CYP3A4 inhibitors"
      ]
    },
    "arms": [
      {"name": "Nexavirin 400mg BID", "participants": 140, "description": "400mg twice daily for 5 days"},
      {"name": "Nexavirin 200mg BID", "participants": 140, "description": "200mg twice daily for 5 days"},
      {"name": "Placebo", "participants": 140, "description": "Matching placebo twice daily for 5 days"}
    ],
    "sites": [
      {"name": "Mass General Brigham", "location": "Boston, MA", "pi": "Dr. Thomas Weber", "enrolled": 82},
      {"name": "Johns Hopkins Medical Center", "location": "Baltimore, MD", "pi": "Dr. Linda Park", "enrolled": 71},
      {"name": "UCSF Medical Center", "location": "San Francisco, CA", "pi": "Dr. Kevin Nguyen", "enrolled": 68},
      {"name": "Cleveland Clinic", "location": "Cleveland, OH", "pi": "Dr. Rachel Stone", "enrolled": 66}
    ],
    "start_date": "2024-06-15",
    "estimated_completion": "2025-12-30",
    "sponsor": "PharmaAgent Therapeutics Inc.",
    "dsmb_review_dates": ["2024-12-01", "2025-06-01", "2025-10-01"],
    "regulatory_submissions": {
      "ind_number": "IND-157832",
      "irb_approval": "2024-05-20",
      "fda_feedback": "Favorable Phase II design accepted"
    }
